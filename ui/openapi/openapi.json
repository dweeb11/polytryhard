            "type": "number",
            "title": "Lower"
          },
          "upper": {
            "type": "number",
            "title": "Upper"
          },
          "predictedMean": {
            "type": "number",
            "title": "Predictedmean"
          },
          "observedFreq": {
            "type": "number",
            "title": "Observedfreq"
          },
          "count": {
            "type": "integer",
            "title": "Count"
          }
        },
        "type": "object",
        "required": [
          "lower",
          "upper",
          "predictedMean",
          "observedFreq",
          "count"
        ],
        "title": "CalibrationBin"
      },
