          },
          "action": {
            "type": "string",
            "title": "Action"
          },
          "targetType": {
            "type": "string",
            "title": "Targettype"
          },
          "targetId": {
            "type": "string",
            "title": "Targetid"
          },
          "beforeState": {
            "additionalProperties": true,
            "type": "object",
            "title": "Beforestate"
          },
          "afterState": {
            "additionalProperties": true,
            "type": "object",
            "title": "Afterstate"
          },
          "reason": {
            "type": "string",
            "title": "Reason"
          },
          "requestId": {
            "type": "string",
            "title": "Requestid"
          }
        },
        "type": "object",
        "required": [
          "id",
          "occurredAt",
          "actor",
          "action",
          "targetType",
          "targetId",
          "beforeState",
          "afterState",
          "reason",
          "requestId"
        ],
        "title": "AuditEvent"
      },
      "CalibrationBin": {
        "properties": {
