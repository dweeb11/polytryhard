# FastAPI application metadata shown by /healthz.
APP_VERSION=0.1.0
GIT_SHA=dev

# Shared append-only database: raw market data, features, references.
DATABASE_URL_SHARED=postgresql+psycopg://polytryhard:polytryhard@postgres:5432/polytryhard_shared

# Per-environment database: staging/main ledgers, audit, signals, portfolios.
DATABASE_URL_PER_ENV=postgresql+psycopg://polytryhard:polytryhard@postgres:5432/polytryhard_staging

# When 1/true, API refuses to start without both DATABASE_URL_* and CONTROL_PLANE_TOKEN set.
# Set 0 for local pytest without Postgres.
REQUIRE_DBS=1

# Bearer token for mutating /v1/* control-plane routes (constant-time compare; never log).
CONTROL_PLANE_TOKEN=change-me-in-production


# Ingestion scheduler (disable for pytest via REQUIRE_DBS=0 fixtures).
SCHEDULER_ENABLED=1
SOURCE_FAILURE_THRESHOLD=3


# Kalshi API (optional — source reports degraded when unset; cassettes drive CI).
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY=
# Host only (no /trade-api/v2); that path is appended by the client. A base that
# already includes /trade-api/v2 is normalized automatically.
KALSHI_API_BASE=https://demo-api.kalshi.co
# Exact Kalshi series_ticker values (comma-separated), e.g. KXHIGHNY — not short prefixes like KXHIGH.
KALSHI_SERIES_PREFIXES=KXHIGHNY

# Comma-separated browser origins allowed to call the API from the UI.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:8080

# UI: backend base URL and matching bearer token for live mode (optional — mock when unset).
PUBLIC_BACKEND_URL=http://localhost:8080
PUBLIC_BACKEND_TOKEN=change-me-in-production
